{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "singleQuote": false,
  "trailingComma": "es5",
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "npm-debug.log*",
    "yarn-debug.log*",
    "yarn-error.log*",
    "pnpm-debug.log*",
    ".env",
    ".env.production",
    ".DS_Store",
    "src/hacks/"
  ]
}
